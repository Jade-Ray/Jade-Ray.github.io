---
import type { CollectionEntry } from "astro:content";
import { getTagHref } from "../utils/tags";

interface Props {
  posts: CollectionEntry<"posts">[];
  showAllLink?: boolean;
}

const { posts, showAllLink = false } = Astro.props;
---

<section class="hero-cyber rounded-2xl mt-8">
  <div class="p-5 lg:p-7">
    <div class="rounded-xl border border-cyan-300/20 bg-slate-950/45 shadow-[inset_0_0_18px_rgba(34,211,238,0.08)]">
      <div class="hero-cyber__terminal-header px-4 py-2.5">
        <div class="hero-cyber__terminal-controls">
          <span class="hero-cyber__terminal-dot hero-cyber__terminal-dot--red"></span>
          <span class="hero-cyber__terminal-dot hero-cyber__terminal-dot--yellow"></span>
          <span class="hero-cyber__terminal-dot hero-cyber__terminal-dot--green"></span>
        </div>
        <p class="text-[0.68rem] uppercase tracking-[0.22em] text-cyan-100/70">latest_posts.stream</p>
      </div>
      <div class="flex flex-wrap items-end justify-between gap-3 px-4 py-4">
        <div>
          <p class="text-xs uppercase tracking-[0.24em] text-cyan-200/75">Journal Stream</p>
          <h2 class="text-2xl font-semibold text-slate-100 sm:text-3xl">Latest Posts</h2>
        </div>
        <p class="text-xs text-cyan-100/60">实时同步最近的研究笔记与想法归档</p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2">

      {
        posts.map((post) => (
          <article class="group rounded-xl border border-cyan-200/15 bg-slate-950/35 p-5 backdrop-blur-sm transition-all duration-300 hover:border-cyan-300/40 hover:bg-slate-900/50 hover:shadow-[0_0_24px_rgba(34,211,238,0.14)]">
            <a href={`/posts/${post.id}`}>
              <h3 class="text-lg font-bold leading-snug text-cyan-200 transition-colors group-hover:text-cyan-100 sm:text-xl">
                {post.data.title}
              </h3>
              {post.data.subtitle && (
                <h4 class="mt-2 text-sm text-slate-400/95">{post.data.subtitle}</h4>
              )}
            </a>
            <p class="mt-3 text-xs uppercase tracking-[0.18em] text-cyan-100/55">
              Posted on{" "}
              {post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>
            {post.data.excerpt && (
              <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-slate-300/85">{post.data.excerpt}</p>
            )}
            <div class="mt-4 flex items-center justify-between gap-3">
              <a
                href={`/posts/${post.id}`}
                class="inline-flex items-center rounded-md border border-cyan-300/35 bg-cyan-500/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100 transition-all hover:border-cyan-200/65 hover:bg-cyan-400/20 hover:text-white"
              >
                Read More
              </a>
            </div>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <a href={getTagHref(tag)} class="tag-chip tag-chip--compact">
                    #{tag}
                  </a>
                ))}
              </div>
            )}
          </article>
        ))
      }
    </div>

    {
      showAllLink && (
        <div class="pt-5 text-center">
          <a
            href="/blog"
            class="inline-flex items-center justify-center rounded-lg border border-cyan-300/35 bg-cyan-500/10 px-5 py-2.5 text-sm font-semibold text-cyan-100 transition-all hover:border-cyan-200/65 hover:bg-cyan-400/20 hover:text-white"
          >
            查看全部文章 →
          </a>
        </div>
      )
    }
  </div>
</section>
