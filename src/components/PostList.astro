---
import type { CollectionEntry } from "astro:content";
import { getTagHref } from "../utils/tags";

interface Props {
  posts: CollectionEntry<"posts">[];
  showAllLink?: boolean;
}

const { posts, showAllLink = false } = Astro.props;
---

<section class="space-y-6">
  <h2 class="text-2xl font-semibold border-b border-gray-700 pb-3 mb-6">
    Latest Posts
  </h2>

  {
    posts.map((post) => (
      <article class="bg-white/10 backdrop-blur-md rounded-xl p-6 hover:bg-white/15 transition-all">
        <a href={`/posts/${post.id}`}>
          <h3 class="text-xl font-bold text-blue-300 hover:underline mb-1">
            {post.data.title}
          </h3>
          {post.data.subtitle && (
            <h4 class="text-gray-400 mb-2">{post.data.subtitle}</h4>
          )}
        </a>
        <p class="text-sm text-gray-400 mb-3">
          Posted on{" "}
          {post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>
        {post.data.excerpt && (
          <p class="text-gray-300 line-clamp-3 mb-3">{post.data.excerpt}</p>
        )}
        <a
          href={`/posts/${post.id}`}
          class="text-blue-400 hover:text-white text-sm transition-colors"
        >
          [Read More]
        </a>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <a href={getTagHref(tag)} class="tag-chip tag-chip--compact">
                #{tag}
              </a>
            ))}
          </div>
        )}
      </article>
    ))
  }

  {
    showAllLink && (
      <div class="pt-3 text-center">
        <a
          href="/blog"
          class="inline-flex items-center justify-center px-5 py-2 rounded-lg bg-blue-500/20 text-blue-300 hover:bg-blue-500/30 hover:text-white transition-all"
        >
          查看全部文章 →
        </a>
      </div>
    )
  }
</section>
