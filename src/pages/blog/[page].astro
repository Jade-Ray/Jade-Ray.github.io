---
import RootLayout from "../../layouts/RootLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { getTagHref } from "../../utils/tags";

export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const posts = (await getCollection("posts")).sort(
    (a: CollectionEntry<"posts">, b: CollectionEntry<"posts">) =>
      b.data.date.getTime() - a.data.date.getTime(),
  );

  const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
  const paths = [];

  for (let page = 2; page <= totalPages; page += 1) {
    const start = (page - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;
    paths.push({
      params: { page: String(page) },
      props: {
        posts: posts.slice(start, end),
        currentPage: page,
        totalPages,
      },
    });
  }

  return paths;
}

interface Props {
  posts: CollectionEntry<"posts">[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
const pageHref = (page: number) => (page === 1 ? "/blog" : `/blog/${page}`);
const prevHref = currentPage === 2 ? "/blog" : `/blog/${currentPage - 1}`;
const nextHref = currentPage < totalPages ? `/blog/${currentPage + 1}` : null;
---

<RootLayout title={`Blog | Page ${currentPage} | Jade-Ray`} description={`Blog page ${currentPage} of ${totalPages}`}>
  <div class="space-y-4">
    <h1 class="text-3xl font-bold mb-8 border-b border-gray-700 pb-4">Latest Posts</h1>

    <ul class="space-y-3">
      {
        posts.map((post) => (
          <li>
            <article class="group rounded-xl border border-white/8 bg-white/5 p-4 transition-all duration-300 hover:border-blue-400/25 hover:bg-white/10 hover:shadow-lg hover:shadow-blue-950/20">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:gap-4">
                <time class="shrink-0 text-sm text-gray-500">
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                <div class="min-w-0 flex-1 space-y-2">
                  <a href={`/posts/${post.id}`} class="block min-w-0">
                    <span class="text-base font-semibold text-blue-300 transition-colors group-hover:text-blue-200 group-hover:underline">
                      {post.data.title}
                    </span>
                  </a>
                  {post.data.subtitle && (
                    <p class="text-sm text-gray-400">{post.data.subtitle}</p>
                  )}
                  {
                    post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.map((tag) => (
                          <a href={getTagHref(tag)} class="tag-chip tag-chip--compact">
                            #{tag}
                          </a>
                        ))}
                      </div>
                    )
                  }
                </div>
              </div>
            </article>
          </li>
        ))
      }
    </ul>

    {
      totalPages > 1 && (
        <nav class="mt-8 flex flex-wrap items-center justify-center gap-2 text-sm">
          {
            currentPage > 1 ? (
              <a
                href={prevHref}
                class="px-3 py-1 rounded-lg bg-white/10 text-gray-200 hover:bg-white/20 transition-all"
              >
                上一页
              </a>
            ) : (
              <span class="px-3 py-1 rounded-lg bg-white/5 text-gray-500 cursor-not-allowed">上一页</span>
            )
          }
          {
            pageNumbers.map((page) => (
              page === currentPage ? (
                <span class="px-3 py-1 rounded-lg bg-blue-500/35 text-white font-semibold">{page}</span>
              ) : (
                <a
                  href={pageHref(page)}
                  class="px-3 py-1 rounded-lg bg-white/10 text-gray-200 hover:bg-white/20 transition-all"
                >
                  {page}
                </a>
              )
            ))
          }
          {
            nextHref ? (
              <a
                href={nextHref}
                class="px-3 py-1 rounded-lg bg-blue-500/20 text-blue-300 hover:bg-blue-500/30 hover:text-white transition-all"
              >
                下一页
              </a>
            ) : (
              <span class="px-3 py-1 rounded-lg bg-white/5 text-gray-500">最后一页</span>
            )
          }
        </nav>
      )
    }
  </div>
</RootLayout>
